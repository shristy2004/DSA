class Solution {
    public String convert(String s, int numRows) {
        if (numRows == 1) {
            return s;
        }
        int len = s.length();
        int cycleLen = (numRows - 1) * 2;
        int cycles = len / cycleLen + 1;
        

        char[] Arr = new char[len]; //array to store solution.
        int index = 0; //next index of array

        //the real part
        for (int i = 0; i < numRows; i++) { //for each row
            for (int j = 0; j < cycles; j++) { //for each cycle
                if ( !(i == 0 || i == numRows - 1) ) { //if you are a middle row
                    int temp = cycleLen - 2 * i; //calculate distance to diagonal
                    if (i + j * cycleLen < len) { //is vertical pos is valid
                        Arr[index] = s.charAt(i + j * cycleLen); //add the value at vertical pos
                        index++;
                        if (i + temp + j * cycleLen < len) { //if diagonal pos is valid (will only be valid if vertical pos is valid)
                            Arr[index] = s.charAt(i + temp + j * cycleLen); //add the value at diagonal pos
                            index++;
                        }
                    }
                } else { //if you are the top or bottom row
                    if(i + j*cycleLen < len){ //if vertical pos is valid
                        Arr[index] = s.charAt(i + j * cycleLen); //add
                        index++;
                    } 
                }
            }
        }
        return new String(Arr);
    }
}
