import java.util.Stack;

class Solution {

    public int kthSmallest(TreeNode root, int k) {

        Stack<TreeNode> stack = new Stack<>();

        while (true) {

            // Go to leftmost node
            while (root != null) {
                stack.push(root);
                root = root.left;
            }

            // Visit node
            root = stack.pop();
            k--;

            if (k == 0) {
                return root.val;
            }

            // Move to right subtree
            root = root.right;
        }
    }
}
