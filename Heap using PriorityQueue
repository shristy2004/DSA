import java.util.PriorityQueue;

class HeapExample {

    public static void main(String[] args) {

        // Min Heap
        PriorityQueue<Integer> minHeap =
                new PriorityQueue<>();

        minHeap.add(10);
        minHeap.add(5);
        minHeap.add(20);

        System.out.println(minHeap.poll());
    }
}
